# Git Identity Configuration
GIT_NAME="Your Name"
GIT_EMAIL="your.email@example.com"

# ZeroTier Configuration
# Leave empty to skip ZeroTier installation and join
ZEROTIER_NETWORK_ID=""

# Username of the developer account on this machine (defaults to $USER if empty)
DEV_USER=""

# Optional: Private repository to clone into ~/projects at the end of setup
# Leave empty to skip cloning any private repository
PRIVATE_REPO_URL=""
