# Git Identity Configuration
GIT_NAME="Your Name"
GIT_EMAIL="your.email@example.com"

# ZeroTier Configuration
# Leave empty to skip ZeroTier installation and join
ZEROTIER_NETWORK_ID=""

# Username of the developer account on this machine (defaults to $USER if empty)
DEV_USER=""

# Optional: Your personal fork of ArduPilot to add as a remote named 'fork'
# Example: git@github.com:your-github-username/ardupilot.git
ARDUPILOT_FORK_URL=""

# Optional: Space-separated list of additional repositories to clone into ~/projects
# Example: "git@github.com:your-github-username/plane_maker.git git@github.com:your-github-username/another-repo.git"
EXTRA_REPOS_TO_CLONE=""
